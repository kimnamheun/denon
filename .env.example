# ============================================================
# Next.js
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Auth.js (NextAuth v5)
# 생성 명령: openssl rand -base64 32
# ============================================================
AUTH_SECRET=replace_with_generated_secret
AUTH_TRUST_HOST=true

# ============================================================
# Vercel Postgres (Neon)
# Vercel Dashboard → Storage → Create Database → Postgres
# 자동 주입되는 환경변수:
#   POSTGRES_URL                — connection pool URL (Prisma 권장)
#   POSTGRES_PRISMA_URL         — Prisma 용 pgbouncer URL
#   POSTGRES_URL_NON_POOLING    — direct connection (Prisma migrate 용)
# 로컬 개발 시 .env.local 에 직접 입력
# ============================================================
POSTGRES_PRISMA_URL=postgres://default:password@host/db?sslmode=require&pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://default:password@host/db?sslmode=require

# ============================================================
# AWS S3 (사진 업로드)
# ============================================================
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=dental-platform-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================
# Naver Maps API
# Vercel 환경변수에 등록 시 NEXT_PUBLIC_ 접두사로 클라이언트 노출 가능
# ============================================================
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# ============================================================
# (선택) Upstash Redis - 캐싱/세션
# ============================================================
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# (선택) 이메일 SMTP (Gmail)
# ============================================================
# EMAIL_SERVER_HOST=smtp.gmail.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
# EMAIL_FROM=noreply@dental-platform.com
